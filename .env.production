# Production Environment Configuration
# This file contains production-specific settings
# IMPORTANT: Do not include actual secrets here - use environment variables or secrets management

# Application Environment
NODE_ENV=production
VITE_APP_NAME=PIKAR AI
VITE_APP_VERSION=1.0.0

# API Configuration - Production
VITE_API_BASE_URL=https://api.pikar-ai.com
VITE_BASE44_API_URL=https://api.base44.io
VITE_API_TIMEOUT=30000
VITE_API_RETRIES=3

# Security - Maximum Security for Production
VITE_ENABLE_CSP=true
VITE_ENABLE_HSTS=true
VITE_SECURITY_HEADERS=true
# CSP Report URI should be set via environment variable
# VITE_CSP_REPORT_URI=

# Encryption - Production Strength
VITE_ENCRYPTION_KEY_LENGTH=256
VITE_PBKDF2_ITERATIONS=100000

# Production Features
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false
VITE_LOG_LEVEL=error

# Analytics - Enabled in Production
VITE_ENABLE_ANALYTICS=true
# Actual keys should be set via environment variables:
# VITE_SENTRY_DSN=
# VITE_GA_TRACKING_ID=
# VITE_HOTJAR_ID=

# Feature Flags - Production Ready Features Only
VITE_ENABLE_AI_AGENTS=true
VITE_ENABLE_SOCIAL_MEDIA=true
VITE_ENABLE_QMS=true
VITE_ENABLE_COMPLIANCE=true
VITE_ENABLE_BETA_FEATURES=false

# Performance - Production Optimized
VITE_ENABLE_CODE_SPLITTING=true
VITE_ENABLE_SERVICE_WORKER=true
VITE_CACHE_DURATION=3600

# File Upload - Production Limits
VITE_MAX_FILE_SIZE=52428800
VITE_ALLOWED_FILE_TYPES=image/*,application/pdf,.doc,.docx,.txt
VITE_ENABLE_VIRUS_SCAN=true

# Rate Limiting - Production Limits
VITE_RATE_LIMIT_WINDOW=900000
VITE_RATE_LIMIT_MAX_REQUESTS=100

# Compliance - Full Compliance
VITE_GDPR_ENABLED=true
VITE_CCPA_ENABLED=true
VITE_COOKIE_CONSENT=true

# Localization
VITE_DEFAULT_LOCALE=en-US
VITE_SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE
VITE_ENABLE_RTL=false

# External Services - Keys should be set via environment variables
# VITE_STRIPE_PUBLIC_KEY=
# VITE_GOOGLE_MAPS_API_KEY=
# VITE_RECAPTCHA_SITE_KEY=
# VITE_FACEBOOK_APP_ID=
# VITE_TWITTER_API_KEY=
# VITE_LINKEDIN_CLIENT_ID=
# VITE_INSTAGRAM_CLIENT_ID=
# VITE_OPENAI_API_KEY=
# VITE_ANTHROPIC_API_KEY=

# AI Configuration
VITE_AI_MODEL_TEMPERATURE=0.7
VITE_AI_MAX_TOKENS=2000

# SECURITY REMINDER:
# All sensitive values (API keys, secrets, tokens) should be:
# 1. Set via environment variables in your deployment platform
# 2. Never committed to version control
# 3. Rotated regularly
# 4. Monitored for unauthorized access

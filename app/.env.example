# Pikar-AI App Environment Configuration
# ========================================
# Copy this file to app/.env and fill in your actual values.
# NEVER commit .env files with real secrets to version control.

# =============================================================================
# ENVIRONMENT DETECTION
# =============================================================================
# Used by the validation module to determine which variables are required
# Options: development, staging, production, test
# Default: development
ENVIRONMENT=development

# =============================================================================
# CRITICAL: SUPABASE CONFIGURATION (Required in ALL environments)
# =============================================================================
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# CRITICAL: JWT SECRET (REQUIRED IN PRODUCTION)
# =============================================================================
# SUPABASE_JWT_SECRET: Secret key for verifying JWT tokens.
# 
# *** SECURITY WARNING ***
# This is CRITICAL for production security. Without it:
# - JWT token verification is disabled
# - Authentication can be bypassed
# - Your application is vulnerable to token forgery attacks
#
# Find this in: Supabase Dashboard > Project Settings > API > JWT Secret
# OR generate from your Supabase project's anon key (it's embedded in the JWT)
#
# REQUIRED in production environments. The application will FAIL TO START
# in production without this variable set.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# REQUIRE_STRICT_AUTH: When enabled (1), authentication failures are rejected
# with 401 responses. STRONGLY RECOMMENDED for production.
# Default: 0 (permissive mode for development)
REQUIRE_STRICT_AUTH=1

# ALLOW_ANONYMOUS_CHAT: When enabled (1), allows unauthenticated users to chat.
# WARNING: Only enable in development or for public demo instances.
# Default: 0 (authentication required)
ALLOW_ANONYMOUS_CHAT=0

# SCHEDULER_SECRET: Secret for authenticating Cloud Scheduler requests.
# Required in production for scheduled tasks (daily reports, etc.)
# Generate with: openssl rand -base64 32
# SCHEDULER_SECRET=your_scheduler_secret

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Direct database connection (for migrations/admin tasks)
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_DB_PASSWORD=your_database_password

# Connection pool settings
SUPABASE_MAX_CONNECTIONS=50
SUPABASE_TIMEOUT=60.0

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
# REDIS_PASSWORD=your_redis_password  # If Redis requires authentication

# =============================================================================
# STREAMING AND UPLOAD GUARDRAILS
# =============================================================================
# Maximum simultaneous SSE streams per user across chat and workflow endpoints.
SSE_MAX_CONNECTIONS_PER_USER=3
# Maximum file size accepted by /upload (bytes).
MAX_UPLOAD_SIZE_BYTES=10485760

# =============================================================================
# WORKFLOW CONFIGURATION
# =============================================================================
# Enforce strict workflow tool lookup in production.
# When true, workflows with unresolved tools will fail to start.
WORKFLOW_STRICT_TOOL_RESOLUTION=true

# Enforce guard rails for critical workflow tools.
WORKFLOW_STRICT_CRITICAL_TOOL_GUARD=true

# Disable fallback simulation for real workflow executions.
WORKFLOW_ALLOW_FALLBACK_SIMULATION=false

# Enforce readiness registry gate on workflow starts.
# In production this should remain true.
WORKFLOW_ENFORCE_READINESS_GATE=true

# Backend API URL for internal calls
BACKEND_API_URL=http://localhost:8000

# Shared secret used for internal service-to-service authentication
# between Supabase Edge Functions and the FastAPI backend.
WORKFLOW_SERVICE_SECRET=your_secure_random_secret_here

# Rollout controls
# Emergency kill switch to block workflow starts.
# WORKFLOW_KILL_SWITCH=false
# Canary mode allows workflows only for listed users.
# WORKFLOW_CANARY_ENABLED=false
# WORKFLOW_CANARY_USER_IDS=00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002

# =============================================================================
# GOOGLE AI CONFIGURATION
# =============================================================================
# Gemini Developer API
GOOGLE_API_KEY=your_gemini_api_key

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# Primary and fallback models for agent execution
# Defaults: gemini-2.5-pro (primary), gemini-2.5-flash (fallback)
# GEMINI_AGENT_MODEL_PRIMARY=gemini-2.5-pro
# GEMINI_AGENT_MODEL_FALLBACK=gemini-2.5-flash

# =============================================================================
# APPLICATION URLS
# =============================================================================
# Public URL of the application (required in production for CORS, redirects)
# APP_URL=https://your-app.example.com

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://your-app.example.com,https://admin.example.com

# =============================================================================
# OPTIONAL: EXTERNAL SERVICE API KEYS
# =============================================================================
# Tavily API for web search
# TAVILY_API_KEY=your_tavily_api_key

# Firecrawl API for web scraping
# FIRECRAWL_API_KEY=your_firecrawl_api_key

# Stripe for payments
# STRIPE_API_KEY=sk_test_your_stripe_key

# SendGrid for emails
# SENDGRID_API_KEY=SG.your_sendgrid_key
# SENDGRID_FROM_EMAIL=noreply@your-domain.com

# HubSpot CRM integration
# HUBSPOT_API_KEY=your_hubspot_api_key

# =============================================================================
# DEVELOPMENT / DEBUGGING
# =============================================================================
# Skip environment validation (useful for local development)
# SKIP_ENV_VALIDATION=1

# Bypass import checks (for testing without full dependencies)
# LOCAL_DEV_BYPASS=1

# Session configuration
# SESSION_MAX_EVENTS=40  # Max events loaded per session (context window limit)

DIRECTOR_RENDER_FPS=24
DIRECTOR_MAX_CONCURRENCY=4
REMOTION_RENDER_SCALE=0.5

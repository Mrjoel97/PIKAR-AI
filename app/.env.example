# Pikar-AI App Environment Configuration
# ========================================
# Copy this file to app/.env and fill in your actual values.
# NEVER commit .env files with real secrets to version control.

# =============================================================================
# ENVIRONMENT DETECTION
# =============================================================================
# Used by the validation module to determine which variables are required
# Options: development, staging, production, test
# Default: development
ENVIRONMENT=development

# =============================================================================
# CRITICAL: SUPABASE CONFIGURATION (Required in ALL environments)
# =============================================================================
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# CRITICAL: JWT SECRET (REQUIRED IN PRODUCTION)
# =============================================================================
# SUPABASE_JWT_SECRET: Secret key for verifying JWT tokens.
# 
# *** SECURITY WARNING ***
# This is CRITICAL for production security. Without it:
# - JWT token verification is disabled
# - Authentication can be bypassed
# - Your application is vulnerable to token forgery attacks
#
# Find this in: Supabase Dashboard > Project Settings > API > JWT Secret
# OR generate from your Supabase project's anon key (it's embedded in the JWT)
#
# REQUIRED in production environments. The application will FAIL TO START
# in production without this variable set.
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# REQUIRE_STRICT_AUTH: When enabled (1), authentication failures are rejected
# with 401 responses. STRONGLY RECOMMENDED for production.
# Default: 0 (permissive mode for development)
REQUIRE_STRICT_AUTH=1

# ALLOW_ANONYMOUS_CHAT: When enabled (1), allows unauthenticated users to chat.
# WARNING: Only enable in development or for public demo instances.
# Default: 0 (authentication required)
ALLOW_ANONYMOUS_CHAT=0

# SCHEDULER_SECRET: Secret for authenticating Cloud Scheduler requests.
# Required in production for scheduled tasks (daily reports, etc.)
# Generate with: openssl rand -base64 32
# SCHEDULER_SECRET=your_scheduler_secret

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Direct database connection (for migrations/admin tasks)
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_DB_PASSWORD=your_database_password

# Connection pool settings
SUPABASE_MAX_CONNECTIONS=50
SUPABASE_TIMEOUT=60.0

# =============================================================================
# REDIS CACHE CONFIGURATION
# =============================================================================
# Set to 0 in production when Redis is not provisioned yet.
# When unset, Cloud Run automatically disables localhost Redis wiring.
# REDIS_ENABLED=1
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
# REDIS_PASSWORD=your_redis_password  # If Redis requires authentication

# =============================================================================
# STREAMING AND UPLOAD GUARDRAILS
# =============================================================================
# Maximum simultaneous SSE streams per user across chat and workflow endpoints.
# Redis-backed: enforced globally across all Cloud Run replicas.
SSE_MAX_CONNECTIONS_PER_USER=3
# Maximum new SSE connections per user per minute (rate limiting, HTTP 429).
SSE_MAX_NEW_CONN_PER_MINUTE=10
# Maximum total active SSE connections across all users/replicas (backpressure, HTTP 503).
SSE_MAX_TOTAL_CONNECTIONS=500
# TTL (seconds) for SSE connection slot keys in Redis — covers process-crash orphan cleanup.
SSE_CONN_TTL_SECONDS=300
# Disable eager skill embedding warmup on multi-replica runtimes to avoid startup storms.
SKILL_EMBEDDING_WARMUP_ENABLED=1
# After a Vertex 429/RESOURCE_EXHAUSTED error, pause new embedding requests briefly.
EMBEDDING_QUOTA_COOLDOWN_SECONDS=900
# Maximum file size accepted by /upload (bytes).
MAX_UPLOAD_SIZE_BYTES=10485760
# SSE stream maximum duration in seconds. Default 1770 = 30s safety
# margin under Cloud Run's 1800s --timeout. If raised >= 1800, also raise
# the Cloud Run --timeout in Makefile:107, cloud-run-service.yaml:118,
# cloudrun.yaml:20, and scripts/deploy-fast.ps1:124 in lockstep,
# otherwise the platform may close the connection mid-response (raw 504).
# Cloud Run hard ceiling is 3600s; beyond ~30 min, prefer a background
# job pattern instead of holding the SSE stream open.
SSE_MAX_DURATION_S=1770

# =============================================================================
# WORKFLOW CONFIGURATION
# =============================================================================
# Enforce strict workflow tool lookup in production.
# When true, workflows with unresolved tools will fail to start.
WORKFLOW_STRICT_TOOL_RESOLUTION=true

# Enforce guard rails for critical workflow tools.
WORKFLOW_STRICT_CRITICAL_TOOL_GUARD=true

# Disable fallback simulation for real workflow executions.
WORKFLOW_ALLOW_FALLBACK_SIMULATION=false

# Enforce readiness registry gate on workflow starts.
# In production this should remain true.
WORKFLOW_ENFORCE_READINESS_GATE=true

# Backend API URL for internal calls
BACKEND_API_URL=http://localhost:8000

# Shared secret used for internal service-to-service authentication
# between Supabase Edge Functions and the FastAPI backend.
WORKFLOW_SERVICE_SECRET=your_secure_random_secret_here

# Rollout controls
# Emergency kill switch to block workflow starts.
# WORKFLOW_KILL_SWITCH=false
# Canary mode allows workflows only for listed users.
# WORKFLOW_CANARY_ENABLED=false
# WORKFLOW_CANARY_USER_IDS=00000000-0000-0000-0000-000000000001,00000000-0000-0000-0000-000000000002

# =============================================================================
# GOOGLE AI CONFIGURATION
# =============================================================================
# Production recommendation for the split architecture:
# keep Vertex-backed agent execution on Google and use the service-account key.
GOOGLE_CLOUD_PROJECT=your_vertex_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./secrets/your-vertex-service-account.json
GOOGLE_GENAI_USE_VERTEXAI=1

# Optional local-development fallback only:
# GOOGLE_API_KEY=your_gemini_api_key

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# Primary and fallback models for agent execution on Vertex
GEMINI_AGENT_MODEL_PRIMARY=gemini-2.5-pro
GEMINI_AGENT_MODEL_FALLBACK=gemini-2.5-flash

# =============================================================================
# CONVERSATION SUMMARIZATION
# =============================================================================
# When a session's event count crosses SESSION_MAX_EVENTS (default 80) the
# agent silently loses visibility into older turns ("forgets after a few
# messages"). With this flag ON, SupabaseSessionService summarizes the
# dropped tail via Gemini Flash and prepends the result as a synthetic event
# so the agent retains the gist. Cached in the session_summaries table.
#
# OFF by default — adds a one-time ~1-2s Gemini call on the FIRST session
# load that crosses the boundary (subsequent loads hit the cache). Enable
# after validating the table is in place and Vertex quota has headroom.
ENABLE_CONVERSATION_SUMMARIZER=false

# Regenerate the cached summary once this many new events accumulate past
# the previous summary point. Lower = fresher summaries, more Gemini cost.
SESSION_SUMMARY_REGEN_THRESHOLD=20

# Model + bounds for the summarizer call. Defaults are sized for the
# Gemini 2.5 Flash latency + cost profile.
CONVERSATION_SUMMARIZER_MODEL=gemini-2.5-flash
CONVERSATION_SUMMARIZER_TIMEOUT_S=8.0
CONVERSATION_SUMMARIZER_MAX_OUTPUT_TOKENS=800
CONVERSATION_SUMMARIZER_MAX_INPUT_EVENTS=200

# =============================================================================
# VERTEX IMAGE GENERATION
# =============================================================================
# Image generation uses gemini-2.5-flash-image on Vertex AI. Per-minute quota
# for image gen is much tighter than for text embeddings, so callers that
# fan out (e.g., generating multiple images per chat turn) need throttling
# at the wrapper level — see app/services/vertex_image_service.py.

# Image-capable Gemini model for primary attempts.
VERTEX_IMAGE_MODEL_PRIMARY=gemini-2.5-flash-image

# Optional alternate model. Only honored when different from PRIMARY (set
# this to a real alternate like a future preview model; leaving it equal to
# PRIMARY means no second model is tried, which is the safe default).
VERTEX_IMAGE_MODEL_FALLBACK=gemini-2.5-flash-image

# Retries on transient errors (429/503/504). Total attempts = MAX_RETRIES + 1.
VERTEX_IMAGE_MAX_RETRIES=3

# Base backoff in seconds. Each retry waits BASE * 2^attempt + jitter.
VERTEX_IMAGE_BASE_BACKOFF_S=2.0

# Cap on per-attempt backoff in seconds.
VERTEX_IMAGE_MAX_BACKOFF_S=30.0

# Process-wide concurrency cap. Concurrent callers wait on a semaphore so
# fan-outs don't burst the per-minute quota in lockstep.
VERTEX_IMAGE_CONCURRENCY=2

# =============================================================================
# APPLICATION URLS
# =============================================================================
# Public URL of the application (required in production for CORS, redirects)
# APP_URL=https://your-app.example.com

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://your-app.example.com,https://admin.example.com

# =============================================================================
# OPTIONAL: EXTERNAL SERVICE API KEYS
# =============================================================================
# Tavily API for web search
# TAVILY_API_KEY=your_tavily_api_key

# Firecrawl API for web scraping
# FIRECRAWL_API_KEY=your_firecrawl_api_key

# Stripe for payments (MCP tool for one-off payment links + subscription management on frontend)
# STRIPE_API_KEY=sk_test_your_stripe_key

# Resend for emails
# RESEND_API_KEY=re_your_resend_key
# RESEND_FROM_EMAIL=noreply@your-domain.com
# RESEND_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Forward inbound emails to this address (leave blank to disable forwarding)
# RESEND_FORWARD_TO=

# HubSpot CRM integration
# HUBSPOT_API_KEY=your_hubspot_api_key

# =============================================================================
# DEVELOPMENT / DEBUGGING
# =============================================================================
# Skip environment validation (useful for local development)
# SKIP_ENV_VALIDATION=1

# Bypass import checks (for testing without full dependencies)
# LOCAL_DEV_BYPASS=1

# Session configuration
# SESSION_MAX_EVENTS=40  # Max events loaded per session (context window limit)

DIRECTOR_RENDER_FPS=24
DIRECTOR_MAX_CONCURRENCY=4
REMOTION_RENDER_SCALE=0.5

# Pikar-AI Environment Configuration
# ===================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env files with real secrets to version control.

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# IMPORTANT: Get this from Supabase Dashboard -> Project Settings -> API -> Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gemini Developer API
GOOGLE_API_KEY=your_gemini_api_key

# Enable Remotion rendering (requires npm/node/ffmpeg in container)
REMOTION_RENDER_ENABLED=1
REMOTION_RENDER_TIMEOUT=300

# External API Keys (optional)
# TAVILY_API_KEY=your_tavily_api_key
# FIRECRAWL_API_KEY=your_firecrawl_api_key

# Redis Cache Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# STREAMING AND UPLOAD GUARDRAILS
# =============================================================================
# Maximum simultaneous SSE streams per user across chat and workflow endpoints.
SSE_MAX_CONNECTIONS_PER_USER=3
# Maximum file size accepted by /upload (bytes).
MAX_UPLOAD_SIZE_BYTES=10485760

# Storage
# LOGS_BUCKET_NAME=your-gcs-bucket-name

# Social Media OAuth (optional — only needed for social publishing features)
# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# FACEBOOK_APP_ID=your_facebook_app_id
# FACEBOOK_APP_SECRET=your_facebook_app_secret
# INSTAGRAM_APP_ID=your_instagram_app_id
# INSTAGRAM_APP_SECRET=your_instagram_app_secret
# TWITTER_CLIENT_ID=your_twitter_client_id
# TWITTER_CLIENT_SECRET=your_twitter_client_secret
# YOUTUBE_CLIENT_ID=your_youtube_client_id
# YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
# TIKTOK_CLIENT_KEY=your_tiktok_client_key
# TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Cloud Scheduler Authentication
# SCHEDULER_SECRET=your_scheduler_secret

# Internal service authentication (Supabase Edge Function -> FastAPI backend)
WORKFLOW_SERVICE_SECRET=your_secure_random_secret_here

# Workflow runtime safety.
WORKFLOW_STRICT_TOOL_RESOLUTION=true
WORKFLOW_STRICT_CRITICAL_TOOL_GUARD=true
WORKFLOW_ALLOW_FALLBACK_SIMULATION=false
WORKFLOW_ENFORCE_READINESS_GATE=true
BACKEND_API_URL=http://localhost:8000

# Frontend Supabase (public keys only — safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# LinkedIn Webhook Secret (for verifying inbound webhook signatures)
# LINKEDIN_WEBHOOK_SECRET=your_linkedin_webhook_secret

DIRECTOR_RENDER_FPS=24
DIRECTOR_MAX_CONCURRENCY=4
REMOTION_RENDER_SCALE=0.5

# =============================================================================
# OBSERVABILITY — SENTRY (Phase 51)
# =============================================================================
# Backend DSN — get from Sentry Dashboard -> Project -> Client Keys (DSN).
# Leave blank to disable Sentry in dev environments (no-op when unset).
# SENTRY_DSN_BACKEND=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry auth token for source map upload during CI/CD builds.
# Get from https://sentry.io/settings/auth-tokens/
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token

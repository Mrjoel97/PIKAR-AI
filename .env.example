# PIKAR AI Environment Configuration Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
NODE_ENV=development
VITE_APP_NAME=PIKAR AI
VITE_APP_VERSION=1.0.0

# =============================================================================
# API CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=https://api.pikar-ai.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_TIMEOUT=30000
VITE_API_RETRIES=3

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Configuration (keep secret in production)
VITE_JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
VITE_JWT_EXPIRES_IN=15m
VITE_REFRESH_TOKEN_EXPIRES_IN=7d

# Security Headers
VITE_ENABLE_CSP=true
VITE_ENABLE_HSTS=false
VITE_CSP_REPORT_URI=https://your-domain.com/csp-report
VITE_SECURITY_HEADERS=true

# Encryption Settings
VITE_ENCRYPTION_KEY_LENGTH=256
VITE_PBKDF2_ITERATIONS=100000

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
VITE_MAX_FILE_SIZE=52428800
VITE_ALLOWED_FILE_TYPES=image/*,application/pdf,.doc,.docx,.txt
VITE_ENABLE_VIRUS_SCAN=true

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry Error Monitoring
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
VITE_GA_TRACKING_ID=GA-XXXXXXXXX

# Hotjar Analytics
VITE_HOTJAR_ID=your-hotjar-id

# Enable Analytics
VITE_ENABLE_ANALYTICS=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VITE_ENABLE_AI_AGENTS=true
VITE_ENABLE_SOCIAL_MEDIA=true
VITE_ENABLE_QMS=true
VITE_ENABLE_COMPLIANCE=true
VITE_ENABLE_BETA_FEATURES=false

# PIKAR AI Blueprint Features
FEATURE_NEW_TRIAL_EXPERIENCE=true
FEATURE_TIER_MIGRATION=true
FEATURE_ACCESSIBILITY_IMPROVEMENTS=true
FEATURE_A_B_TESTING=true
FEATURE_ADVANCED_ANALYTICS=true

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================
VITE_ENABLE_CODE_SPLITTING=true
VITE_ENABLE_SERVICE_WORKER=false
VITE_CACHE_DURATION=3600

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false
VITE_LOG_LEVEL=info

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Payment Processing - PIKAR AI Blueprint Compliant
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Product IDs - Blueprint Tiers
STRIPE_SOLOPRENEUR_PRICE_MONTHLY=price_solopreneur_monthly_id
STRIPE_SOLOPRENEUR_PRICE_YEARLY=price_solopreneur_yearly_id
STRIPE_STARTUP_PRICE_MONTHLY=price_startup_monthly_id
STRIPE_STARTUP_PRICE_YEARLY=price_startup_yearly_id
STRIPE_SME_PRICE_MONTHLY=price_sme_monthly_id
STRIPE_SME_PRICE_YEARLY=price_sme_yearly_id

# Trial Configuration
TRIAL_PERIOD_DAYS=7
GRACE_PERIOD_DAYS=3

# Maps
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# reCAPTCHA
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# =============================================================================
# SOCIAL MEDIA API KEYS
# =============================================================================
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_TWITTER_API_KEY=your-twitter-api-key
VITE_LINKEDIN_CLIENT_ID=your-linkedin-client-id
VITE_INSTAGRAM_CLIENT_ID=your-instagram-client-id

# =============================================================================
# AI CONFIGURATION
# =============================================================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key

# AI Model Settings
VITE_AI_MODEL_TEMPERATURE=0.7
VITE_AI_MAX_TOKENS=2000

# =============================================================================
# RATE LIMITING
# =============================================================================
VITE_RATE_LIMIT_WINDOW=900000
VITE_RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# COMPLIANCE & PRIVACY
# =============================================================================
VITE_GDPR_ENABLED=true
VITE_CCPA_ENABLED=false
VITE_COOKIE_CONSENT=true

# =============================================================================
# LOCALIZATION
# =============================================================================
VITE_DEFAULT_LOCALE=en-US
VITE_SUPPORTED_LOCALES=en-US,es-ES,fr-FR,de-DE
VITE_ENABLE_RTL=false

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# These settings are automatically applied in development mode
# VITE_ENABLE_DEBUG=true (auto-enabled in development)
# VITE_LOG_LEVEL=debug (auto-set in development)
# VITE_ENABLE_MOCK_DATA=true (auto-enabled in development)

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# These settings are automatically applied in production mode
# VITE_ENABLE_DEBUG=false (auto-disabled in production)
# VITE_LOG_LEVEL=error (auto-set in production)
# VITE_ENABLE_MOCK_DATA=false (auto-disabled in production)
# VITE_ENABLE_HSTS=true (auto-enabled in production)
# VITE_ENABLE_ANALYTICS=true (auto-enabled in production)
# VITE_ENABLE_SERVICE_WORKER=true (auto-enabled in production)

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. Never commit actual secrets to version control
# 2. Use different values for development, staging, and production
# 3. Rotate secrets regularly in production
# 4. Use environment-specific .env files (.env.local, .env.production, etc.)
# 5. Consider using a secrets management service for production
# 6. Validate all environment variables on application startup
# 7. Use strong, randomly generated secrets for JWT and encryption keys

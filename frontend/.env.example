# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Backend API URL (required in production — falls back to localhost:8000 in dev)
NEXT_PUBLIC_API_URL=https://your-backend.run.app
BACKEND_URL=https://your-backend.run.app

# App URL for OAuth callbacks (required in production)
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app

# Resend email (server-side only — set in Vercel Environment Variables, NOT here)
# RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=Pikar AI <hello@yourdomain.com>
RESEND_AUDIENCE_ID=
RESEND_FROM_EMAIL=hello@yourdomain.com

#### Webhook Configuration
```typescript
interface WebhookConfig {
  id: string;
  name: string;
  url: string;
  events: WebhookEvent[];
  headers: Record<string, string>;
  secret: string;
  enabled: boolean;
  retryPolicy: {
    maxRetries: number;
    backoffMultiplier: number;
    maxBackoffDelay: number;
  };
}

class WebhookManager {
  async createWebhook(config: Omit<WebhookConfig, 'id'>): Promise<string> {
    const webhook: WebhookConfig = {
      id: generateId(),
      ...config
    };
    
    await this.saveWebhookConfig(webhook);
    return webhook.id;
  }
  
  async sendWebhook(webhookId: string, event: WebhookEvent, data: any): Promise<void> {
    const config = await this.getWebhookConfig(webhookId);
    
    if (!config.enabled || !config.events.includes(event)) {
      return;
    }
    
    const payload = {
      event,
      data,
      timestamp: new Date().toISOString(),
      webhook_id: webhookId
    };
    
    await this.deliverWebhook(config, payload);
  }
}

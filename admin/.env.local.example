# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# User-facing app URL (for redirects back to main app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase credentials (same as user app — shared auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Admin session timeout in milliseconds (default: 30 minutes)
# ADMIN_SESSION_TIMEOUT_MS=1800000

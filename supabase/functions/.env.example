
# Supabase URL and Key (Auto-filled by Supabase CLI in local dev)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend)
RESEND_API_KEY=re_123456789

# Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=AAAA...

# SMS (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1234567890

# Calendar Widget
GOOGLE_CALENDAR_API_KEY=AIza...

# Workflow execution
BACKEND_API_URL=http://localhost:8000
# In production set to false to disable simulated edge fallback.
WORKFLOW_ALLOW_FALLBACK_SIMULATION=false
WORKFLOW_STRICT_TOOL_RESOLUTION=true
WORKFLOW_STRICT_CRITICAL_TOOL_GUARD=true
# Shared secret for authenticated calls to backend /workflows/execute-step
WORKFLOW_SERVICE_SECRET=dev_secret_change_in_production
